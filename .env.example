# ─── Local AI Security Gateway Configuration ──────────────────────
# Copy this file to .env and customize as needed.

# Gateway listen address
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=8000

# Default upstream AI provider (used when client connects to localhost)
# Options: openai, anthropic, google, groq, mistral, deepseek, xai, cohere, together, openrouter, ollama
DEFAULT_PROVIDER=openai

# Custom upstream URL (overrides DEFAULT_PROVIDER if set)
# CUSTOM_UPSTREAM_URL=https://your-custom-api.com

# Upstream proxy (for VPN / Clash / V2Ray)
# HTTPS_PROXY=http://127.0.0.1:7890

# Request timeout in seconds
UPSTREAM_TIMEOUT=120

# Enable/disable DLP scanning
DLP_ENABLED=true

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
